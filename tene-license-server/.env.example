# Tene License Server — הגדרות
# העתק לקובץ .env ומלא את הערכים

# סיסמת ממשק הניהול — החלף לסיסמה חזקה!
ADMIN_PASSWORD=changeme

# פורט
PORT=4000

# תיקיית גיבויים (ברירת מחדל: ./backups)
# BACKUP_DIR=/var/backups/tene

# נתיב DB (ברירת מחדל: ./licenses.db)
# DB_PATH=/var/data/licenses.db

# הטלפון שלך לקבלת התראות (WA)
# TENE_NOTIFY_PHONE=972501234567
