# ── Priority ERP ──────────────────────────────────────────────────
PRIORITY_BASE_URL=https://your-company.priorityerp.com
PRIORITY_USER=api_user
PRIORITY_PASS=api_password
PRIORITY_COMPANY=your_company_name

# ── WhatsApp Business API (Meta) ──────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_verify_token

# ── Google Cloud Vision (OCR) ─────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# OR use API key:
GOOGLE_VISION_API_KEY=your_google_vision_api_key

# ── Email (IMAP) ──────────────────────────────────────────────────
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=ironbend@your-domain.com
EMAIL_IMAP_PASS=your_app_password
EMAIL_POLL_INTERVAL_MS=60000

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
SESSION_SECRET=החלף_במחרוזת_אקראית_ארוכה_לפחות_32_תווים

# ── Database & Backup ─────────────────────────────────────────────
# DB_PATH – נתיב לקובץ SQLite (ברירת מחדל: ./ironbend.db)
DB_PATH=./ironbend.db
# BACKUP_DIR – תיקיית גיבויים יומית (ברירת מחדל: ./backups)
BACKUP_DIR=./backups

# ── Gemini AI ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
